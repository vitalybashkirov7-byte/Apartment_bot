# ============================================
# Файл переменных окружения
# ============================================
# 1. Скопируйте этот файл в .env
# 2. Заполните значения
# 3. НИКОГДА не коммитьте .env в Git!

# ============================================
# ОБЯЗАТЕЛЬНЫЕ НАСТРОЙКИ
# ============================================

# Telegram Bot Token (получите у @BotFather)
TELEGRAM_BOT_TOKEN=ваш_токен_здесь

# Telegram ID разработчика (для обратной связи)
# Получить: напишите @userinfobot в Telegram
DEV_CHAT_ID=ваш_id_здесь

# ============================================
# ПАРАМЕТРЫ ПОИСКА
# ============================================

# Минимальная площадь (м²)
MIN_AREA=90

# Максимальная цена (рубли)
MAX_PRICE=17000000

# Минимальное количество комнат
MIN_ROOMS=3

# Минимальное количество санузлов
MIN_BATHROOMS=2

# Максимальный срок давности публикации (дни)
MAX_PUBLICATION_AGE_DAYS=3

# ============================================
# ЛИМИТЫ
# ============================================

# Максимум запросов в минуту на пользователя
RATE_LIMIT_PER_MINUTE=5

# Максимум запросов в день на пользователя
DAILY_LIMIT_PER_USER=50

# ============================================
# ЛОГИРОВАНИЕ
# ============================================

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
# DEBUG включает кнопку "Дашборд" в боте
LOG_LEVEL=INFO

# Максимальный размер лог-файла (в МБ)
MAX_LOG_SIZE_MB=50

# ============================================
# ПРОКСИ (для Telegram API)
# ============================================
# Включайте когда Karing или другой VPN запущен.
# Прокси используется ТОЛЬКО для Telegram API (через HTTPXRequest).
# Парсеры НЕ используют прокси — они работают напрямую.
# Без прокси Telegram API недоступен из РФ.

# true = включить прокси для Telegram (нужен запущенный Karing/VPN)
# false = прокси не используется (парсеры работают, Telegram — нет)
USE_PROXY=false

# Адрес прокси (используется только при USE_PROXY=true)
HTTP_PROXY=http://127.0.0.1:3067
HTTPS_PROXY=http://127.0.0.1:3067

# Порты Karing: HTTP=10809, SOCKS5=10808
# Порты по умолчанию (если Karing на стандартных настройках):
# HTTP_PROXY=http://127.0.0.1:10809
# HTTPS_PROXY=http://127.0.0.1:10809

# ============================================
# ДОПОЛНИТЕЛЬНО
# ============================================

# Имя бота (для отображения в логах)
BOT_NAME=@ваш_бот

# Фото при старте (URL или путь к файлу start_photo.jpg)
# START_PHOTO_URL=https://example.com/photo.jpg
