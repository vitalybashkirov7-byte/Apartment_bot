# ============================================
# Файл переменных окружения
# ============================================
# 1. Скопируйте этот файл в .env
# 2. Заполните значения
# 3. НИКОГДА не коммитьте .env в Git!

# ============================================
# ОБЯЗАТЕЛЬНЫЕ НАСТРОЙКИ
# ============================================

# ⚠️ TELEGRAM_BOT_TOKEN НЕ хранится в .env!
# Установите как системную переменную Windows:
#   [Environment]::SetEnvironmentVariable("TELEGRAM_BOT_TOKEN", "ваш_токен", "User")
# Или через cmd:
#   setx TELEGRAM_BOT_TOKEN "ваш_токен"
# Перезапустите терминал после установки.

# Telegram ID разработчика (для обратной связи и уведомлений)
# Получить: напишите @userinfobot в Telegram
DEV_CHAT_ID=ваш_id_здесь

# ============================================
# ПАРАМЕТРЫ ПОИСКА
# ============================================

# Минимальная площадь (м²)
MIN_AREA=91

# Максимальная цена (рубли)
MAX_PRICE=18000000

# Минимальное количество комнат
MIN_ROOMS=3

# Минимальное количество санузлов (парсеры не извлекают — ставится 1)
MIN_BATHROOMS=1

# Максимальный срок давности публикации (дни, 0 = без ограничений)
MAX_PUBLICATION_AGE_DAYS=3

# ============================================
# ЛИМИТЫ
# ============================================

# Максимум запросов в минуту на пользователя
RATE_LIMIT_PER_MINUTE=5

# Максимум запросов в день на пользователя
DAILY_LIMIT_PER_USER=20

# ============================================
# ЛОГИРОВАНИЕ
# ============================================

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
# DEBUG включает: кнопку "Дашборд" + "Тест парсеров" в боте
LOG_LEVEL=DEBUG

# Максимальный размер лог-файла (в МБ), ротация с 5 бэкапами
MAX_LOG_SIZE_MB=1

# ============================================
# ПРОКСИ (для Telegram API)
# ============================================
# Включайте когда Karing или другой VPN запущен.
# Прокси используется ТОЛЬКО для Telegram API.
# Парсеры НЕ используют прокси — работают напрямую.
# Без прокси Telegram API недоступен из РФ (блокировка провайдера).

# true = включить прокси для Telegram (нужен запущенный Karing/VPN)
# false = прокси не используется
USE_PROXY=true

# Адрес прокси (используется только при USE_PROXY=true)
HTTP_PROXY=http://127.0.0.1:3067
HTTPS_PROXY=http://127.0.0.1:3067

# Стандартные порты Karing:
# HTTP  = http://127.0.0.1:10809
# SOCKS5 = socks5://127.0.0.1:10808

# ============================================
# ДОПОЛНИТЕЛЬНО
# ============================================

# Имя бота (для отображения в логах)
BOT_NAME=@search_flat_nsk_bot

# Фото при старте (URL или путь к файлу start_photo.jpg)
# START_PHOTO_URL=https://example.com/photo.jpg

# ============================================
# ФАЙЛЫ (не редактировать)
# ============================================
# avito_cookies.pkl     — cookies для Авито (создаётся через test_avito_auth.py)
# domclick_cookies.pkl  — cookies для Домклик (создаётся через test_domclick_auth.py)
# user_settings.json    — настройки пользователей (авто-создаётся)
# bot.log               — лог-файл с ротацией
